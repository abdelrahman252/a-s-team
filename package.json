{
  "name": "as-team-dashboard",
  "version": "1.0.15",
  "description": "A's Team TikTok + Khod-Whaat Analytics Dashboard",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist:mac": "electron-builder --mac --x64 && electron-builder --mac --arm64",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder --mac --win",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac --publish always",
    "release:all": "electron-builder --mac --win --publish always"
  },
  "build": {
    "appId": "com.asteam.dashboard",
    "productName": "A's Team Dashboard",
    "copyright": "Copyright © 2025",
    "icon": "assets/icon",
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "abdelrahman252",
      "repo": "a-s-team",
      "releaseType": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.md"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.icns",
      "artifactName": "A.s.Team.Dashboard-${version}-${arch}-mac.${ext}",
      "identity": null,
      "target": [
        {
          "target": "dmg"
        },
        {
          "target": "zip"
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "artifactName": "A.s.Team.Dashboard.Setup.${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "A's Team Dashboard"
    },
    "portable": {
      "artifactName": "A.s.Team.Dashboard.Portable.${version}.${ext}"
    },
    "dmg": {
      "title": "A's Team Dashboard",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.9",
    "playwright-core": "^1.52.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  }
}

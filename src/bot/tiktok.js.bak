"use strict";

/**
 * tiktok.js — TikTok Ads spend scraper
 *
 * KEY BEHAVIOUR (shared login):
 * ─────────────────────────────
 *  • All TikTok accounts share ONE login (same Ads Manager account).
 *  • Chrome is launched ONCE per bot run and kept open across all members.
 *  • Login is confirmed ONCE at the start of the run. If the session is already
 *    saved (persistent profile), it skips straight to scraping.
 *  • If TikTok redirects to the login page mid-run (session expired / no-permission),
 *    the bot detects it, waits for the user to log in again, then resumes.
 *  • Chrome is closed only after ALL members are processed.
 *
 * ALL elements are inside nested Shadow DOM — must use page.evaluate() to reach them.
 * Component suffix is "-1-1-19" (all selectors include "-1-1-14" as fallback).
 *
 * CALENDAR LAYOUT: The picker shows TWO side-by-side months (left=earlier, right=later).
 * - LEFT panel:  visible ← controls, RIGHT controls have class --hidden
 * - RIGHT panel: visible → controls, LEFT controls have class --hidden
 * - To navigate FORWARD: click → on the RIGHT panel (the one WITHOUT --hidden on its right controls).
 * - To navigate BACKWARD: click ← on the LEFT panel (the one WITHOUT --hidden on its left controls).
 *
 * Flow per account:
 *   1. Navigate to clean campaign URL
 *   2. Detect & recover session if redirected to login page
 *   3. Click the date picker trigger (ks-date-time-picker-display-field-1-1-19)
 *   4. Set date range — click FROM day, click TO day
 *   5. Click Confirm (ks-button-1-1-19[data-testid="core-index-g1HneZ"])
 *   6. Wait for table, read spend from div[slot="footer-stat_cost"]
 */

const { launchChrome, closeChrome } = require("./browser");

const TT_LOGIN_URL = "https://ads.tiktok.com/i18n/login";
const MONTH_NAMES  = ["January","February","March","April","May","June",
                      "July","August","September","October","November","December"];

function lg(onLog, type, msg) { onLog({ type, msg }); }

function parseSpend(text) {
  if (!text) return 0;
  const m = text.replace(/,/g, "").match(/[\d]+\.?\d*/);
  const v = m ? parseFloat(m[0]) : 0;
  return isNaN(v) ? 0 : v;
}

// ════════════════════════════════════════════════════════
// SHARED CHROME STATE
// One context + page is opened at the start of a run and
// reused across all members. Closed once at the end.
//
// MUTEX: because members now run in parallel we need to
// serialise access to the shared page.  A simple promise-
// chain mutex is enough — no external deps needed.
// ════════════════════════════════════════════════════════

let _sharedContext = null;
let _sharedPage    = null;

// Lightweight async mutex — each caller waits for the previous one to finish.
let _tiktokMutexTail = Promise.resolve();

/**
 * Acquire the shared-page lock, run fn(), then release.
 * This ensures only one member uses the shared TikTok page at a time.
 */
async function withTiktokLock(fn) {
  let release;
  const acquired = new Promise(res => { release = res; });
  // Queue: wait for the previous holder to finish, then run
  const previous = _tiktokMutexTail;
  _tiktokMutexTail = previous.then(() => acquired);
  await previous;       // wait our turn
  try {
    return await fn();
  } finally {
    release();          // hand off to the next waiter
  }
}

/** Call once before any members are processed. */
async function initSharedChrome(onLog, launchMinimized) {
  if (_sharedContext && _sharedPage) return; // already open
  // Reset the mutex for a fresh run
  _tiktokMutexTail = Promise.resolve();
  const { context, page } = await launchChrome(onLog, "tiktok-shared", launchMinimized);
  _sharedContext = context;
  _sharedPage    = page;
}

/** Call once after all members are processed. */
async function closeSharedChrome(onLog) {
  if (_sharedContext) {
    await closeChrome(_sharedContext, onLog);
    _sharedContext = null;
    _sharedPage    = null;
  }
}

// ════════════════════════════════════════════════════════
// SESSION HELPERS
// ════════════════════════════════════════════════════════

function isLoginUrl(url) {
  return (
    url.includes("/login") ||
    url.includes("/auth")  ||
    url.includes("redirect=") ||
    !url.includes("ads.tiktok.com")
  );
}

/**
 * Ensure TikTok session is active.
 * If we're on a login page, wait for the user to log in (up to 10 min).
 * Returns true when session is confirmed.
 */
async function ensureSession(page, onLog, contextLabel) {
  const url = page.url();
  if (!isLoginUrl(url)) return true; // already logged in

  lg(onLog, "warn", `⚠️ [${contextLabel}] Session expired or not logged in — on login page`);
  lg(onLog, "warn", `👆 [${contextLabel}] Please log in to TikTok Ads in the browser window (up to 10 min)...`);

  const deadline = Date.now() + 10 * 60 * 1000;
  while (Date.now() < deadline) {
    await page.waitForTimeout(1500);
    const u = page.url();
    if (!isLoginUrl(u)) {
      lg(onLog, "ok", `✅ [${contextLabel}] Login confirmed — resuming`);
      return true;
    }
  }
  throw new Error(`[${contextLabel}] TikTok login timeout — session could not be confirmed`);
}

/**
 * One-time login check at the start of the run.
 * Navigates to the login URL to see if session is already saved.
 */
async function confirmInitialLogin(page, onLog) {
  lg(onLog, "info", "🔑 Checking TikTok session...");
  await page.goto(TT_LOGIN_URL, { waitUntil: "domcontentloaded", timeout: 30000 });
  await page.waitForTimeout(800);

  const url = page.url();
  if (!isLoginUrl(url)) {
    lg(onLog, "ok", "✅ Already logged in (saved session) — skipping login");
    return;
  }

  // Need to log in
  await ensureSession(page, onLog, "initial login");
}

// ════════════════════════════════════════════════════════
// SHADOW DOM HELPERS
// ════════════════════════════════════════════════════════

async function evalShadow(page, finderFn) {
  return page.evaluate((fnStr) => {
    const fn = new Function("root", fnStr);
    function walk(root) {
      const r = fn(root);
      if (r) return r;
      for (const el of root.querySelectorAll("*")) {
        if (el.shadowRoot) {
          const r2 = walk(el.shadowRoot);
          if (r2) return r2;
        }
      }
      return null;
    }
    return walk(document);
  }, finderFn);
}

// ── OPEN DATE PICKER ──
async function openDatePicker(page, onLog) {
  lg(onLog, "info", "   🗓️  Opening date picker...");

  let clicked = await page.evaluate(() => {
    function walk(root) {
      const fields = root.querySelectorAll("[class*='KsDateRangePicker'] ks-date-time-picker-display-field-1-1-19, ks-date-time-picker-display-field-1-1-19, ks-date-time-picker-display-field-1-1-14");
      for (const f of fields) {
        if (f.shadowRoot) {
          const btn = f.shadowRoot.querySelector("button");
          if (btn) { btn.click(); return true; }
        }
      }
      for (const el of root.querySelectorAll("*")) {
        if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
      }
      return false;
    }
    return walk(document);
  });
  lg(onLog, "info", `   🗓️  Try 1 result: ${clicked}`);

  if (!clicked) {
    clicked = await page.evaluate(() => {
      function walk(root) {
        for (const el of root.querySelectorAll("*")) {
          if (el.tagName && el.tagName.toLowerCase().includes("display-field") && el.shadowRoot) {
            const btn = el.shadowRoot.querySelector("button");
            if (btn) { btn.click(); return true; }
          }
          if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
        }
        return false;
      }
      return walk(document);
    });
    lg(onLog, "info", `   🗓️  Try 2 result: ${clicked}`);
  }

  if (!clicked) {
    clicked = await page.evaluate(() => {
      function walk(root) {
        for (const el of root.querySelectorAll("button, div[class*='display-field']")) {
          const t = el.textContent || "";
          if (/Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec/.test(t) && t.length < 40) {
            el.click(); return true;
          }
        }
        for (const el of root.querySelectorAll("*")) {
          if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
        }
        return false;
      }
      return walk(document);
    });
    lg(onLog, "info", `   🗓️  Try 3 result: ${clicked}`);
  }

  if (!clicked) {
    clicked = await page.evaluate(() => {
      const el = document.querySelector("[class*='picker--']");
      if (el) { el.click(); return true; }
      return false;
    });
    lg(onLog, "info", `   🗓️  Try 4 result: ${clicked}`);
  }

  await page.waitForTimeout(300);

  const calOpen = await page.evaluate(() => {
    function walk(root) {
      if (root.querySelector(".date-grid-body__date-item")) return true;
      for (const el of root.querySelectorAll("*")) {
        if (el.shadowRoot && walk(el.shadowRoot)) return true;
      }
      return false;
    }
    return walk(document);
  });
  lg(onLog, calOpen ? "ok" : "warn", `   🗓️  Calendar open: ${calOpen}`);

  return calOpen;
}

// ── GET CURRENT MONTH/YEAR ──
async function getCurrentMonthYear(page) {
  return page.evaluate(() => {
    const MONTHS = ["January","February","March","April","May","June",
                    "July","August","September","October","November","December"];
    function walk(root) {
      const btns = root.querySelectorAll("button.date-grid-header__labels-part--clickable");
      if (btns.length >= 2) {
        const month = btns[0].textContent.trim();
        const year  = parseInt(btns[1].textContent.trim());
        const mi    = MONTHS.indexOf(month);
        if (mi >= 0 && !isNaN(year)) return { monthIdx: mi, year, monthName: month };
      }
      for (const el of root.querySelectorAll("*")) {
        if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
      }
      return null;
    }
    return walk(document);
  });
}

// ── NAVIGATE TO TARGET MONTH ──
async function navigateToMonth(page, targetYear, targetMonth, onLog) {
  for (let i = 0; i < 24; i++) {
    const cur = await getCurrentMonthYear(page);
    if (!cur) { lg(onLog, "warn", "   🗓️  Could not read current month"); break; }
    lg(onLog, "info", `   🗓️  Calendar shows: ${cur.monthName} ${cur.year} → want: ${MONTH_NAMES[targetMonth]} ${targetYear}`);
    if (cur.year === targetYear && cur.monthIdx === targetMonth) break;

    const curTotal    = cur.year * 12 + cur.monthIdx;
    const targetTotal = targetYear * 12 + targetMonth;
    const goBack      = targetTotal < curTotal;

    const moved = await page.evaluate((goBack) => {
      // The picker shows TWO calendar panels side-by-side.
      // LEFT panel:  has visible ← (go back) controls, RIGHT controls are hidden.
      // RIGHT panel: has visible → (go forward) controls, LEFT controls are hidden.
      // We must click the arrow on the panel whose controls are NOT hidden.
      // Strategy: collect all ks-icon-button-* that wrap the target icon AND whose
      // parent .date-grid-header__controls does NOT have --hidden class.

      function tryClickVisibleArrow(root) {
        // Find all date-grid-header elements (they sit in shadow roots of ks-date-time-picker-date-grid-header-*)
        const headers = root.querySelectorAll("[class*='date-grid__header'], ks-date-time-picker-date-grid-header-1-1-19, ks-date-time-picker-date-grid-header-1-1-14");
        for (const header of headers) {
          const sr = header.shadowRoot;
          if (!sr) continue;
          // Each header shadow has .date-grid-header__controls divs (one left, one right)
          const controlGroups = sr.querySelectorAll(".date-grid-header__controls");
          for (const group of controlGroups) {
            // Skip hidden control groups
            if (group.classList.contains("date-grid-header__controls--hidden")) continue;
            // Look for the icon we want inside this visible group
            const iconTag = goBack ? "ks-icon-chevron-left" : "ks-icon-chevron-right";
            const icon = group.querySelector(iconTag);
            if (!icon) continue;
            // Click the ks-icon-button wrapper's inner shadow button
            const iconBtn = icon.closest("ks-icon-button-1-1-19") || icon.closest("ks-icon-button-1-1-14") || icon.closest("[class*='KsIconButton']");
            if (iconBtn && iconBtn.shadowRoot) {
              const btn = iconBtn.shadowRoot.querySelector("button");
              if (btn) { btn.click(); return true; }
            }
            // Fallback: click the icon itself
            icon.click(); return true;
          }
        }
        // Recurse into shadow roots we haven't visited yet
        for (const el of root.querySelectorAll("*")) {
          if (el.shadowRoot) { const r = tryClickVisibleArrow(el.shadowRoot); if (r) return r; }
        }
        return false;
      }
      return tryClickVisibleArrow(document);
    }, goBack);

    lg(onLog, "info", `   🗓️  Navigate ${goBack ? "←" : "→"}: ${moved}`);
    await page.waitForTimeout(200);
  }
}

// ── CLICK A SPECIFIC DAY ──
async function clickDay(page, day, targetMonth, targetYear, onLog) {
  const dayStr = String(day);
  lg(onLog, "info", `   🗓️  Clicking day ${dayStr} (${MONTH_NAMES[targetMonth]} ${targetYear})...`);

  let clicked = await page.evaluate((dayStr) => {
    function walk(root) {
      const items = root.querySelectorAll(".date-grid-body__date-item");
      for (const item of items) {
        const t = item.textContent.trim();
        const cls = item.className || "";
        if (t === dayStr && !cls.includes("outside-current-period")) {
          item.click(); return true;
        }
      }
      for (const el of root.querySelectorAll("*")) {
        if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
      }
      return false;
    }
    return walk(document);
  }, dayStr);
  lg(onLog, "info", `   🗓️  Day click try 1 (class match): ${clicked}`);

  if (!clicked) {
    clicked = await page.evaluate((dayStr) => {
      function walk(root) {
        const items = root.querySelectorAll(`[data-testid$="-${dayStr}"]`);
        for (const item of items) {
          const cls = item.className || "";
          if (!cls.includes("outside-current-period") && !cls.includes("decorative")) {
            item.click(); return true;
          }
        }
        for (const el of root.querySelectorAll("*")) {
          if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
        }
        return false;
      }
      return walk(document);
    }, dayStr);
    lg(onLog, "info", `   🗓️  Day click try 2 (data-testid): ${clicked}`);
  }

  await page.waitForTimeout(150);
  return clicked;
}

// ── CLICK CONFIRM ──
//
// The Confirm button lives here (from actual HTML inspection):
//   .picker-core__popup-footer
//     .picker-core__popup-footer-append
//       ks-button-1-1-19[data-testid="core-index-g1HneZ"]  ← Confirm
//         <template shadowrootmode="open">
//           <button class="button button--sm button--type-contained button--color-primary">
//
// RULES:
//  - NEVER click page-level buttons or "last button" fallbacks — they hit "Create Campaign".
//  - All tries must stay inside .picker-core__popup-footer-append or the picker popup.
//  - Try by testid first, then by text content "Confirm" inside the footer only.
//
async function clickConfirm(page, onLog) {
  lg(onLog, "info", "   🗓️  Clicking Confirm...");

  // ── Try 1: exact testid "core-index-g1HneZ" — works when suffix is -1-1-19 ──
  let clicked = await page.evaluate(() => {
    function walk(root) {
      // Try both known suffixes in case TikTok rolls back
      const selectors = [
        'ks-button-1-1-19[data-testid="core-index-g1HneZ"]',
        'ks-button-1-1-14[data-testid="core-index-g1HneZ"]',
      ];
      for (const sel of selectors) {
        const host = root.querySelector(sel);
        if (host) {
          // Button is inside shadow root via <template shadowrootmode>
          const btn = host.shadowRoot?.querySelector("button");
          if (btn) { btn.click(); return `testid-shadow-${sel}`; }
          // Shadow not attached yet — click the host element itself
          host.click(); return `testid-host-${sel}`;
        }
      }
      for (const el of root.querySelectorAll("*")) {
        if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
      }
      return null;
    }
    return walk(document);
  });
  lg(onLog, "info", `   🗓️  Confirm try 1 (testid): ${clicked}`);
  if (clicked) { await page.waitForTimeout(500); return; }

  // ── Try 2: find .picker-core__popup-footer-append, click ks-button whose text is "Confirm" ──
  clicked = await page.evaluate(() => {
    function findFooterAppend(root) {
      const el = root.querySelector(".picker-core__popup-footer-append");
      if (el) return el;
      for (const c of root.querySelectorAll("*")) {
        if (c.shadowRoot) { const r = findFooterAppend(c.shadowRoot); if (r) return r; }
      }
      return null;
    }
    const footer = findFooterAppend(document);
    if (!footer) return "no-footer";
    // Walk ks-button-* inside the footer append div
    const ksButtons = footer.querySelectorAll(
      "ks-button-1-1-19, ks-button-1-1-14, ks-button-91z, [class*='KsButton']"
    );
    for (const kb of ksButtons) {
      const label = (kb.textContent || "").trim();
      if (label === "Confirm") {
        const btn = kb.shadowRoot?.querySelector("button");
        if (btn) { btn.click(); return "footer-ksbutton-shadow"; }
        kb.click(); return "footer-ksbutton-host";
      }
    }
    // Also try plain <button> with text Confirm inside footer
    const plainBtns = footer.querySelectorAll("button");
    for (const b of plainBtns) {
      if ((b.textContent || "").trim() === "Confirm") { b.click(); return "footer-plain-button"; }
    }
    return null;
  });
  lg(onLog, "info", `   🗓️  Confirm try 2 (footer-append text): ${clicked}`);
  if (clicked && clicked !== "no-footer" && clicked !== "null") { await page.waitForTimeout(500); return; }

  // ── Try 3: walk ALL shadow roots, find any ks-button whose text is Confirm,
  //           but ONLY if it's inside a .picker-core__popup ancestor ──
  clicked = await page.evaluate(() => {
    function insidePickerPopup(el) {
      let node = el;
      while (node) {
        if (node.classList && (
          node.classList.contains("picker-core__popup") ||
          node.classList.contains("picker-core__popup-footer") ||
          node.classList.contains("picker-core__popup-footer-append")
        )) return true;
        node = node.parentElement || (node.getRootNode && node.getRootNode().host);
      }
      return false;
    }
    function walk(root) {
      const candidates = root.querySelectorAll(
        "ks-button-1-1-19, ks-button-1-1-14, ks-button-91z"
      );
      for (const kb of candidates) {
        if ((kb.textContent || "").trim() !== "Confirm") continue;
        if (!insidePickerPopup(kb)) continue;
        const btn = kb.shadowRoot?.querySelector("button");
        if (btn) { btn.click(); return "popup-scoped-shadow"; }
        kb.click(); return "popup-scoped-host";
      }
      for (const el of root.querySelectorAll("*")) {
        if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
      }
      return null;
    }
    return walk(document);
  });
  lg(onLog, "info", `   🗓️  Confirm try 3 (popup-scoped walk): ${clicked}`);
  if (clicked) { await page.waitForTimeout(500); return; }

  // ── Try 4: data-testid partial match — "core-index-" suffix buttons inside footer ──
  clicked = await page.evaluate(() => {
    function findFooterAppend(root) {
      const el = root.querySelector(".picker-core__popup-footer-append");
      if (el) return el;
      for (const c of root.querySelectorAll("*")) {
        if (c.shadowRoot) { const r = findFooterAppend(c.shadowRoot); if (r) return r; }
      }
      return null;
    }
    const footer = findFooterAppend(document);
    if (!footer) return "no-footer";
    // Get all ks-button-* with a data-testid; the LAST one is always Confirm
    const all = [...footer.querySelectorAll("[data-testid]")].filter(el =>
      el.tagName && el.tagName.toLowerCase().startsWith("ks-button")
    );
    if (all.length === 0) return "no-testid-buttons";
    const last = all[all.length - 1];
    const btn = last.shadowRoot?.querySelector("button");
    if (btn) { btn.click(); return `footer-last-testid:${last.dataset.testid}`; }
    last.click(); return `footer-last-host:${last.dataset.testid}`;
  });
  lg(onLog, "info", `   🗓️  Confirm try 4 (footer last testid): ${clicked}`);
  if (clicked && !clicked.startsWith("no-")) { await page.waitForTimeout(500); return; }

  // ── Try 5: Use data-testid from known HTML — "core-index-g1HneZ" anywhere in DOM ──
  clicked = await page.evaluate(() => {
    function walk(root) {
      const el = root.querySelector('[data-testid="core-index-g1HneZ"]');
      if (el) {
        const btn = el.shadowRoot?.querySelector("button");
        if (btn) { btn.click(); return "global-testid-shadow"; }
        el.click(); return "global-testid-host";
      }
      for (const c of root.querySelectorAll("*")) {
        if (c.shadowRoot) { const r = walk(c.shadowRoot); if (r) return r; }
      }
      return null;
    }
    return walk(document);
  });
  lg(onLog, "info", `   🗓️  Confirm try 5 (global testid g1HneZ): ${clicked}`);
  if (clicked) { await page.waitForTimeout(500); return; }

  lg(onLog, "warn", "   🗓️  ⚠️  All Confirm tries failed — date may not be applied");
  await page.waitForTimeout(500);
}

// ════════════════════════════════════════════════════════
// SET DATE RANGE
// ════════════════════════════════════════════════════════
async function setDateRange(page, dateFrom, dateTo, onLog) {
  const fY = dateFrom.getFullYear(), fM = dateFrom.getMonth(), fD = dateFrom.getDate();
  const tY = dateTo.getFullYear(),   tM = dateTo.getMonth(),   tD = dateTo.getDate();
  const isSame = fY===tY && fM===tM && fD===tD;

  lg(onLog, "info", `📅 Setting date: ${MONTH_NAMES[fM]} ${fD} ${fY}${isSame ? " (single)" : " → " + MONTH_NAMES[tM] + " " + tD + " " + tY}`);

  const opened = await openDatePicker(page, onLog);
  if (!opened) {
    lg(onLog, "warn", "⚠️ Calendar may not have opened — trying to continue anyway");
  }
  await page.waitForTimeout(200);

  await navigateToMonth(page, fY, fM, onLog);
  await page.waitForTimeout(150);
  await clickDay(page, fD, fM, fY, onLog);
  await page.waitForTimeout(150);

  if (isSame) {
    lg(onLog, "info", `   🗓️  Single date — clicking day ${fD} again for TO...`);
    await clickDay(page, fD, fM, fY, onLog);
  } else {
    await navigateToMonth(page, tY, tM, onLog);
    await page.waitForTimeout(150);
    await clickDay(page, tD, tM, tY, onLog);
  }
  await page.waitForTimeout(150);

  await clickConfirm(page, onLog);
  lg(onLog, "ok", "✅ Date range set and confirmed");
  await page.waitForTimeout(500);
}

// ════════════════════════════════════════════════════════
// READ SPEND
// ════════════════════════════════════════════════════════
async function waitForTable(page, ms, onLog) {
  lg(onLog, "info", "   💰 Waiting for table to load...");
  const start = Date.now();
  while (Date.now() - start < ms) {
    // ── Check for session expiry mid-wait ──
    if (isLoginUrl(page.url())) {
      lg(onLog, "warn", "   ⚠️ Redirected to login while waiting for table — session expired");
      return "login";
    }
    const found = await page.evaluate(() => {
      if (document.querySelector("tfoot")) return "tfoot";
      function walk(root) {
        if (root.querySelector("[slot='footer-stat_cost']")) return "slot";
        for (const el of root.querySelectorAll("*")) {
          if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
        }
        return null;
      }
      return walk(document);
    });
    if (found) { lg(onLog, "info", `   💰 Table found (${found})`); return found; }
    await page.waitForTimeout(600);
  }
  lg(onLog, "warn", `   💰 Table not found after ${ms/1000}s`);
  return null;
}

async function readSpend(page, onLog) {
  const tableResult = await waitForTable(page, 25000, onLog);
  if (tableResult === "login") return "SESSION_EXPIRED";

  lg(onLog, "info", "   💰 Reading spend...");

  let result = await page.evaluate(() => {
    const slotDiv = document.querySelector('div[slot="footer-stat_cost"]');
    if (!slotDiv) return { found: false, method: "no-slot-div" };
    // Try new suffix first, then old
    const ksText = slotDiv.querySelector("ks-text-1-1-19") || slotDiv.querySelector("ks-text-1-1-14");
    if (ksText) {
      const t = ksText.textContent?.trim();
      if (t) return { found: true, text: t, method: "ks-text-slot" };
    }
    const t = slotDiv.textContent?.trim();
    return t ? { found: true, text: t, method: "slot-div-text" } : { found: false, method: "empty-slot" };
  });
  lg(onLog, "info", `   💰 Try 1 (slot div): found=${result.found} method=${result.method} text="${result.text || ""}"`);
  if (result.found && result.text && result.text !== "—") return parseSpend(result.text);

  result = await page.evaluate(() => {
    function walk(root) {
      const slot = root.querySelector('[slot="footer-stat_cost"]');
      if (slot) {
        const t = slot.textContent?.trim();
        if (t && t !== "—") return { found: true, text: t, method: "shadow-walk-slot" };
      }
      for (const el of root.querySelectorAll("*")) {
        if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
      }
      return { found: false };
    }
    return walk(document);
  });
  lg(onLog, "info", `   💰 Try 2 (shadow walk slot): found=${result.found} text="${result.text || ""}"`);
  if (result.found && result.text) return parseSpend(result.text);

  result = await page.evaluate(() => {
    const tfoot = document.querySelector("tfoot");
    if (!tfoot) return { found: false, method: "no-tfoot" };
    const th = tfoot.querySelector('[data-testid*="stat_cost"], [slot*="stat_cost"]');
    if (th) return { found: true, text: th.textContent?.trim(), method: "tfoot-testid" };
    const ths = [...tfoot.querySelectorAll("th")];
    const texts = ths.map(t => t.textContent?.trim()).filter(Boolean);
    return { found: texts.length > 0, text: texts.join(" | "), method: "tfoot-all-ths" };
  });
  lg(onLog, "info", `   💰 Try 3 (tfoot): found=${result.found} text="${result.text || ""}"`);
  if (result.found && result.text) {
    const m = result.text.match(/[\d,]+\.?\d*\s*(SAR|USD|EGP|AED)/);
    if (m) return parseSpend(m[0]);
  }

  result = await page.evaluate(() => {
    function walk(root) {
      const texts = root.querySelectorAll("ks-text-1-1-19, ks-text-1-1-14, ks-text-91z");
      for (const el of texts) {
        const t = el.textContent?.trim() || "";
        if (/[\d,]+\.?\d*\s*(SAR|USD|EGP|AED)/.test(t)) {
          return { found: true, text: t, method: "ks-text-currency" };
        }
      }
      for (const el of root.querySelectorAll("*")) {
        if (el.shadowRoot) { const r = walk(el.shadowRoot); if (r) return r; }
      }
      return { found: false };
    }
    return walk(document);
  });
  lg(onLog, "info", `   💰 Try 4 (ks-text currency): found=${result.found} text="${result.text || ""}"`);
  if (result.found && result.text) return parseSpend(result.text);

  lg(onLog, "warn", "   💰 All spend methods failed — using 0");
  return 0;
}

// ════════════════════════════════════════════════════════
// WAIT FOR CAMPAIGNS PAGE
// ════════════════════════════════════════════════════════
async function waitForCampaignsPage(page, aadvid, onLog) {
  lg(onLog, "info", `   🌐 Waiting for campaigns page (aadvid: ${aadvid})...`);
  const deadline = Date.now() + 3 * 60 * 1000;
  let lastLog = 0;

  while (Date.now() < deadline) {
    const url = page.url();

    // ── Session expiry check ──
    if (isLoginUrl(url)) {
      lg(onLog, "warn", "   ⚠️ TikTok redirected to login page — session expired");
      await ensureSession(page, onLog, `account ${aadvid || "?"}`);
      // After re-login, navigate back to the account URL
      return false; // caller will re-navigate
    }

    if (Date.now() - lastLog > 5000) {
      lg(onLog, "info", `   🌐 URL: ${url.slice(0, 90)}`);
      lastLog = Date.now();
    }

    if (!aadvid || url.includes(aadvid)) {
      const pickerFound = await page.evaluate(() => {
        function walk(root) {
          for (const el of root.querySelectorAll("*")) {
            if (el.tagName && el.tagName.toLowerCase().includes("display-field") && el.shadowRoot) {
              const btn = el.shadowRoot.querySelector("button");
              if (btn) return true;
            }
            if (el.shadowRoot && walk(el.shadowRoot)) return true;
          }
          return false;
        }
        return walk(document);
      });

      if (pickerFound) {
        lg(onLog, "ok", "   ✅ Campaigns page ready — date picker found in shadow DOM");
        return true;
      }
      lg(onLog, "info", "   🌐 On campaigns page but picker not ready yet...");
    }

    await page.waitForTimeout(2000);
  }
  lg(onLog, "warn", "   ⚠️ Campaigns page wait timed out — trying anyway");
  return true;
}

// ════════════════════════════════════════════════════════
// SCRAPE ONE ACCOUNT
// ════════════════════════════════════════════════════════
async function scrapeAccount(page, accountUrl, dateFrom, dateTo, onLog) {
  lg(onLog, "info", `   🌐 Account URL: ${accountUrl.slice(0, 80)}`);

  let cleanUrl = accountUrl;
  let aadvid = null;
  try {
    const u = new URL(accountUrl);
    aadvid = u.searchParams.get("aadvid");
    if (aadvid) cleanUrl = `https://ads.tiktok.com/i18n/manage/campaign?aadvid=${aadvid}`;
    lg(onLog, "info", `   🌐 Clean URL: ${cleanUrl}`);
  } catch (e) {
    lg(onLog, "warn", `   🌐 URL parse error: ${e.message}`);
  }

  // Navigate — with one retry if session expired mid-navigation
  for (let attempt = 0; attempt < 2; attempt++) {
    lg(onLog, "info", `   🌐 Navigating... (attempt ${attempt + 1})`);
    await page.goto(cleanUrl, { waitUntil: "domcontentloaded", timeout: 30000 });
    await page.waitForTimeout(800);

    // Check for session expiry right after navigation
    if (isLoginUrl(page.url())) {
      lg(onLog, "warn", "   ⚠️ Redirected to login after navigation — recovering session...");
      await ensureSession(page, onLog, `account ${aadvid || "?"}`);
      // Loop back and navigate again after re-login
      continue;
    }

    break; // navigation successful
  }

  await waitForCampaignsPage(page, aadvid, onLog);

  // Final session check before scraping
  if (isLoginUrl(page.url())) {
    await ensureSession(page, onLog, `pre-scrape ${aadvid || "?"}`);
    await page.goto(cleanUrl, { waitUntil: "domcontentloaded", timeout: 30000 });
    await page.waitForTimeout(800);
    await waitForCampaignsPage(page, aadvid, onLog);
  }

  lg(onLog, "info", "   📅 Setting date range...");
  await setDateRange(page, dateFrom, dateTo, onLog);

  // ── Guard: detect accidental navigation to campaign creation ──
  const postDateUrl = page.url();
  if (postDateUrl.includes("/creation/") || postDateUrl.includes("/create/campaign")) {
    lg(onLog, "warn", `   ⚠️ Detected accidental navigation to campaign creation page after date set!`);
    lg(onLog, "warn", `   ⚠️ URL: ${postDateUrl.slice(0, 120)}`);
    lg(onLog, "warn", `   ⚠️ Pressing Escape and navigating back...`);
    await page.keyboard.press("Escape");
    await page.waitForTimeout(300);
    await page.goto(cleanUrl, { waitUntil: "domcontentloaded", timeout: 30000 });
    await page.waitForTimeout(800);
    await waitForCampaignsPage(page, aadvid, onLog);
    lg(onLog, "info", "   📅 Re-setting date range after recovery...");
    await setDateRange(page, dateFrom, dateTo, onLog);
  }

  lg(onLog, "info", "   💰 Reading spend...");
  let spend = await readSpend(page, onLog);

  // If session expired while reading spend, recover and retry once
  if (spend === "SESSION_EXPIRED") {
    lg(onLog, "warn", "   ⚠️ Session expired while reading spend — recovering...");
    await ensureSession(page, onLog, `spend-read ${aadvid || "?"}`);
    await page.goto(cleanUrl, { waitUntil: "domcontentloaded", timeout: 30000 });
    await page.waitForTimeout(800);
    await waitForCampaignsPage(page, aadvid, onLog);
    await setDateRange(page, dateFrom, dateTo, onLog);
    spend = await readSpend(page, onLog);
    if (spend === "SESSION_EXPIRED") {
      lg(onLog, "warn", "   ⚠️ Spend still unreadable after re-login — using 0");
      spend = 0;
    }
  }

  lg(onLog, "ok", `   ✅ Spend: ${spend}`);
  return spend;
}

// ════════════════════════════════════════════════════════
// MAIN — per-member entry point
// ════════════════════════════════════════════════════════
async function runTikTok({ member, dateFrom, dateTo, onLog, launchMinimized, sharedPage, cancelToken }) {
  const fromDate = new Date(dateFrom);
  const toDate   = new Date(dateTo || dateFrom);

  const accounts = (member.tiktokAccounts || []).filter(a => a && a.trim() !== "");
  if (accounts.length === 0) {
    lg(onLog, "warn", `⚠️ No TikTok accounts for ${member.name}`);
    return { success: true, memberId: member.id, totalSpend: 0 };
  }

  lg(onLog, "info", `━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`);
  lg(onLog, "info", `🎵 TikTok: ${member.name} — ${accounts.length} account(s) [waiting for shared page...]`);
  lg(onLog, "info", `   Date: ${fromDate.toDateString()} → ${toDate.toDateString()}`);

  // Use the shared page — serialised via mutex so parallel members don't clash
  return withTiktokLock(async () => {
    const page = sharedPage || _sharedPage;
    if (!page) throw new Error("TikTok: shared Chrome page not initialised — call initSharedChrome first");

    lg(onLog, "info", `🎵 TikTok: ${member.name} — acquired shared page, scraping now`);

    try {
      // Check for stop before beginning account scraping
      if(cancelToken && cancelToken.cancelled){lg(onLog,"warn","⏹ Stop requested — TikTok skipping scrape.");return{success:true,memberId:member.id,totalSpend:0};}
      let totalSpend = 0;
      for (let i = 0; i < accounts.length; i++) {
        if(cancelToken && cancelToken.cancelled){lg(onLog,"warn","⏹ Stop requested — TikTok stopping account loop.");break;}
        lg(onLog, "info", `\n🎵 ── Account ${i + 1}/${accounts.length} ──`);
        try {
          const spend = await scrapeAccount(page, accounts[i], fromDate, toDate, onLog);
          totalSpend += (typeof spend === "number" ? spend : 0);
          lg(onLog, "ok", `🎵 Account ${i + 1}: ${spend} | Total so far: ${totalSpend}`);
        } catch (err) {
          lg(onLog, "warn", `⚠️ Account ${i + 1} error: ${err.message} — using 0`);
        }
      }

      lg(onLog, "ok", `✅ TikTok total for ${member.name}: ${totalSpend}`);
      return { success: true, memberId: member.id, totalSpend };

    } catch (err) {
      lg(onLog, "error", `❌ TikTok fatal [${member.name}]: ${err.message}`);
      return { success: false, memberId: member.id, totalSpend: 0, error: err.message };
    }
  });
}

function _getSharedPage() { return _sharedPage; }

module.exports = { runTikTok, initSharedChrome, closeSharedChrome, confirmInitialLogin, _getSharedPage };
